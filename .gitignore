# 运行时生成：托管监控任务（含推送 token，勿提交）
monitor_jobs.json

# 运行时生成：自动抢票任务（含推送 token，勿提交）
order_jobs.json

# 运行时生成：12306 登录态 Cookie（敏感，绝不能提交）
login_session.json

# Chrome DevTools 导出的临时 12306 Cookie（敏感）
qp_12306_cookies.json

# 本地加密密钥（绝不能提交：泄露则等于敏感文件可解密）
.secret.key

# 访问令牌（绝不能提交：泄露则等于鉴权失效）
.app_token

# 管理员令牌（绝不能提交：泄露则别人可控制所有人的任务）
.admin_token

# Flask 会话签名密钥（绝不能提交：泄露则可伪造会话）
.flask_secret

# macOS
.DS_Store

# Python
__pycache__/
*.pyc

# 虚拟环境
.venv/
